  dialogueMark: {fileID: 1678112527}
  audioSource: {fileID: 100227886}
  soundOnAppear: {fileID: 0}
  dialogueLines:
  - "Hechicera Eleonore:\nQue tal viajero, \xBFEstas en busca de peligro?\npues estas
    de suerte "
  - "M\xE1s all\xE1 de esas rocas te encontraras con un lugar lleno de monstruos
    y tesoros."
  - "\xBFEstas preparado para entrar?"
  - "Caeras de una gran altura, \xA1Buena suerte!"
  typingTime: 0.05
